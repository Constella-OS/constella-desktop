{
  "name": "Constella",
  "version": "2.3.1",
  "description": "Constella: the modern way to take notes and actually do things with them.",
  "homepage": "./",
  "license": "MIT",
  "author": {
    "name": "Beemo AI",
    "email": "hey@beemo.ai",
    "url": "https://beemo.ai"
  },
  "main": "./src/main/main.ts",
  "scripts": {
    "build": "concurrently \"npm run build:main\" \"npm run build:renderer\"",
    "build:dll": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.renderer.dev.dll.ts --stats",
    "build:main": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.main.prod.ts --stats",
    "build:renderer": "cross-env NODE_ENV=production TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.renderer.prod.ts",
    "postinstall": "ts-node .erb/scripts/check-native-dep.js && electron-builder install-app-deps && npm run build:dll",
    "lint": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx",
    "package-dev": "cross-env NODE_ENV=development ts-node ./.erb/scripts/clean.js dist && npm run build && electron-builder build --publish never --arm64 && npm run build:dll",
    "package": "cross-env NODE_ENV=production ts-node ./.erb/scripts/clean.js dist && npm run build && electron-builder build --publish never --arm64 && npm run build:dll",
    "release": "cross-env NODE_ENV=production ts-node ./.erb/scripts/clean.js dist && npm run build && electron-builder build --publish always --arm64 && npm run build:dll && ./sentry.sh",
    "package-others": "ts-node ./.erb/scripts/clean.js dist && npm run build && electron-builder build -wl --publish never && npm run build:dll",
    "release-others": "cross-env NODE_ENV=production ts-node ./.erb/scripts/clean.js dist && npm run build && electron-builder build -wl --publish always && npm run build:dll",
    "package-win": "ts-node ./.erb/scripts/clean.js dist && npm run build && electron-builder build -w --publish never && npm run build:dll",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional --module-dir release/app",
    "start": "cross-env NODE_ENV=development ts-node ./.erb/scripts/check-port-in-use.js && npm run start:renderer",
    "start:main": "cross-env NODE_ENV=development NODE_OPTIONS=--import=tsx electronmon . --inspect=9229",
    "start:preload": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack --config ./.erb/configs/webpack.config.preload.dev.ts",
    "start:renderer": "cross-env NODE_ENV=development TS_NODE_TRANSPILE_ONLY=true webpack serve --config ./.erb/configs/webpack.config.renderer.dev.ts",
    "test": "jest",
    "format": "npx prettier --write ."
  },
  "browserslist": [],
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ]
  },
  "jest": {
    "moduleDirectories": [
      "node_modules",
      "release/app/node_modules",
      "src"
    ],
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/.erb/mocks/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy"
    },
    "setupFiles": [
      "./.erb/scripts/check-build-exists.ts"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "testPathIgnorePatterns": [
      "release/app/dist",
      ".erb/dll",
      "web"
    ],
    "transform": {
      "\\.(ts|tsx|js|jsx)$": "ts-jest"
    }
  },
