  "build": {
    "productName": "Constella",
    "appId": "app.constella.constella",
    "copyright": "Copyright © 2025 Beemo AI",
    "buildVersion": "2.3.1",
    "extraMetadata": {
      "version": "2.3.1",
      "author": "Beemo AI"
    },
    "asar": false,
    "asarUnpack": "**\\*.{node,dll}",
    "files": [
      "dist",
      "node_modules",
      "package.json"
    ],
    "afterSign": ".erb/scripts/notarize.js",
    "mac": {
      "target": [
        "default"
      ],
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "For Stella Assist mode, this is needed for having conversations with your voice.",
        "NSCameraUsageDescription": "For Stella Assist mode, this is needed for having conversations although camera is not used."
      },
      "publish": {
        "provider": "s3",
        "bucket": "aicc-bucket",
        "region": "us-east-2",
        "acl": null,
        "path": "constella/publish"
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "include": "assets/check_vcredist.nsh"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "app": "release/app",
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "s3",
      "bucket": "aicc-bucket",
      "region": "us-east-2",
      "acl": null,
      "path": "constella/publish"
    },
    "protocols": [
      {
        "name": "Constella App Desktop",
        "schemes": [
          "constella-app-desktop"
        ]
      }
    ],
    "releaseInfo": {
      "releaseNotes": "Auto connecting and mindmap generation!"
    }
  },
  "engines": {
    "node": ">=14.x",
    "npm": ">=7.x"
  },
  "electronmon": {
    "patterns": [
      "!**/**",
      "src/main/**"
    ],
    "logLevel": "quiet"
  },
  "overrides": {
    "react-error-overlay": "6.0.9"
  }
}
