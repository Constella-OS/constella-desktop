# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and loaded by webpack at build time.
# All variables are optional — features gracefully degrade when unset.

# Firebase (required for auth)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Analytics (leave empty to disable)
POSTHOG_TOKEN=
MIXPANEL_TOKEN=

# Error tracking (leave empty to disable)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# PDF→DOCX export via ConvertAPI (leave empty to disable)
CONVERT_API_TOKEN=
